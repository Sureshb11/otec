# ─────────────────────────────────────────────────────────────────
# OTEC Frontend — Environment Variables
# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.
# ─────────────────────────────────────────────────────────────────

# ── Option A: Local dev with MOCK data (no backend needed) ───────
VITE_USE_MOCK_API=true
VITE_API_BASE_URL=/api

# ── Option B: Local dev with REAL backend (NestJS on :3000) ──────
# VITE_USE_MOCK_API=false
# VITE_API_BASE_URL=/api

# ── Option C: Point directly at Vercel backend (no local server) ─
# VITE_USE_MOCK_API=false
# VITE_API_BASE_URL=https://backend-blush-omega-65.vercel.app
